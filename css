body{

margin:0;
font-family:Helvetica;
background:white;
color:#111;

}

header{

display:flex;
justify-content:space-between;
align-items:center;

padding:20px;

background:black;
color:white;

}

nav a{

color:white;
margin-left:20px;
text-decoration:none;

}

.hero{

height:300px;

display:flex;
flex-direction:column;
justify-content:center;
align-items:center;

background:#f5f5f5;

text-align:center;

}

.newsletter{

padding:40px;
text-align:center;

}

.newsletter input{

padding:12px;
width:230px;

}

.newsletter button{

padding:12px 20px;

background:black;
color:white;
border:none;

}

.products{

display:grid;

grid-template-columns:repeat(auto-fit,minmax(260px,1fr));

gap:30px;

padding:40px;

}

.product{

border:1px solid #ddd;

padding:15px;

}

.product img{

width:100%;

}

.buy{

display:block;

margin-top:10px;

background:black;
color:white;

padding:10px;

text-align:center;

text-decoration:none;

}

footer{

text-align:center;
padding:20px;

background:#eee;

}
